# All optional. Copy to .env and fill what you want on.
# Without any of these: email sign-in works (codes shown in dev), WCA-ID
# linking works, Google and "Sign in with WCA" stay hidden.

# --- Google sign-in (same value as client VITE_GOOGLE_CLIENT_ID) ---
# https://console.cloud.google.com/apis/credentials  (Web application)
GOOGLE_CLIENT_ID=

# --- Real "Sign in with WCA" (OAuth) ---
# Register an OAuth application at:
#   https://www.worldcubeassociation.org/oauth/applications
# Scopes: public.  Redirect URI must be your backend callback below.
WCA_CLIENT_ID=
WCA_CLIENT_SECRET=
WCA_REDIRECT_URI=http://localhost:4000/api/auth/wca/callback
# Where the app runs, for the post-login bounce-back:
APP_URL=http://localhost:5173

# --- Email delivery (verification codes) ---
# No provider yet: codes are shown in dev and logged. When ready, wire AWS SES
# in server/src/mailer.ts and set your region + verified sender here.
# AWS_REGION=
# EMAIL_FROM=
