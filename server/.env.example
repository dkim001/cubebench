# All optional. Copy to .env and fill what you want on.
# Without any of these: email + password sign-in works; Google stays hidden;
# Pro falls back to an early-access email capture (no checkout).

# --- Google sign-in (same value as client VITE_GOOGLE_CLIENT_ID) ---
# https://console.cloud.google.com/apis/credentials  (Web application)
GOOGLE_CLIENT_ID=

# --- Stripe (real Pro subscription) ---
# 1. Create a product + recurring $3/mo price at https://dashboard.stripe.com
#    (Test mode first). Copy the price id (price_...).
# 2. Get your secret key (sk_test_... / sk_live_...).
# 3. Create a webhook to <this server>/api/billing/webhook for events
#    customer.subscription.created/updated/deleted; copy its signing secret.
#    Locally: `stripe listen --forward-to localhost:4000/api/billing/webhook`.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Where the app runs, for Checkout redirects back:
APP_URL=http://localhost:5173
